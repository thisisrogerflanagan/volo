<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Volo Screensaver</title>
  <meta name="description" content="{{ description or 'The soothing pulse of mechanical split-flaps, reimagined for your Mac.' }}">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://thisisroger.xyz/volo/">
  <meta property="og:title" content="{{ title }} | Volo Screensaver">
  <meta property="og:description" content="{{ description or 'The soothing pulse of mechanical split-flaps, reimagined for your Mac.' }}">
  <meta property="og:image" content="https://thisisroger.xyz/volo/assets/img/preview.png">

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://thisisroger.xyz/volo/">
  <meta property="twitter:title" content="{{ title }} | Volo Screensaver">
  <meta property="twitter:description" content="{{ description or 'The soothing pulse of mechanical split-flaps, reimagined for your Mac.' }}">
  <meta property="twitter:image" content="https://thisisroger.xyz/volo/assets/img/preview.png">

  <link rel="icon" type="image/png" href="{{ '/assets/img/logo.png' | url }}">
  <link rel="apple-touch-icon" href="{{ '/assets/img/logo@2x.png' | url }}">
  <link rel="stylesheet" href="{{ '/scss/main.css' | url }}">
  <script src="https://unpkg.com/@dotlottie/player-component@latest/dist/dotlottie-player.mjs" type="module"></script>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-1B6MVDY2XN"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-1B6MVDY2XN');
  </script>
</head>
<body>
  <header class="sticky-header">
    <div class="header-content">
      <div class="header-left">
        <img src="{{ '/assets/img/logo.png' | url }}" alt="Volo Icon" class="header-logo">
      </div>
      <div class="header-right">
        <a href="{{ '/buy-now/' | url }}" class="btn-header-cta">Get Volo</a>
      </div>
    </div>
  </header>
  <div class="container">
    <main>
      {{ content | safe }}
    </main>
  </div>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top-row">
        <div class="footer-brand">
          <img src="{{ '/assets/img/logo.png' | url }}" alt="Volo Icon" class="footer-logo">
          <span class="footer-logo-text">Volo</span>
        </div>
        <nav class="footer-main-nav">
          <a href="https://thisisroger.gumroad.com/" target="_blank">Gumroad</a>
          <a href="{{ '/newsletter/' | url }}">Newsletter</a>
          <a href="https://thisisroger.xyz/" target="_blank">About</a>
          <a href="mailto:support@voloapp.com">Help</a>
          <a href="{{ '/faqs/' | url }}">FAQs</a>
        </nav>
