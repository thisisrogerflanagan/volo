---
layout: layouts/base.njk
title: Newsletter
---
<div class="faq-page-container" data-page="newsletter">
    <nav class="faq-nav">
        <div class="faq-nav-left">
            <a href="{{ '/' | url }}" class="faq-nav-logo">
                <img src="{{ '/assets/img/logo.png' | url }}" alt="Volo Icon">
                <span class="faq-app-name">Volo</span>
                <span class="faq-app-version">v1.0</span>
            </a>
        </div>
        <div class="faq-nav-right">
            <a href="{{ '/buy-now/' | url }}" class="btn-download-mac">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.1 2.48-1.34.03-1.77-.79-3.29-.79-1.53
                        0-2.01.77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87
                        3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42
                        1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.36 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35
                        1.05-3.11z"></path>
                </svg>
                Download for Mac
            </a>
        </div>
    </nav>

    <header class="faq-page-header">
    </header>

    <div class="newsletter-content">
        <div class="coming-soon-board" id="newsletter-board">
            {% set text = "COMING SOON" %}
            {% for i in range(0, 11) %}
                <div class="flip" data-value="{{ text[i] if text[i] else ' ' }}">
                    <div>{{ text[i] if text[i] else ' ' }}</div>
                    <div>{{ text[i] if text[i] else ' ' }}</div>
                    <div>{{ text[i] if text[i] else ' ' }}</div>
                    <div>{{ text[i] if text[i] else ' ' }}</div>
                </div>
            {% endfor %}
        </div>

        <div class="newsletter-form-container">
            <p>Join the inner circle. Get occasional updates on new scenery, mechanical experiments, and the art of time.</p>
            <form name="newsletter" method="POST" data-netlify="true" class="signup-form">
                <input type="email" name="email" placeholder="email@example.com" required>
                <button type="submit" class="btn-submit">Keep me updated</button>
            </form>
        </div>
    </div>

    <div class="faq-help-footer">
        <h2>Have more questions?</h2>
        <p>If you have any additional questions, do not hesitate to <a href="mailto:thisisrogerflanagan@gmail.com" class="faq-contact-link">contact us</a>.</p>
    </div>
</div>

<script src="{{ '/js/flip.js' | url }}"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const board = document.getElementById('newsletter-board');
        if (!board) return;

        const slots = Array.from(board.querySelectorAll('.flip')).map(el => new FlipSlot(el));
        const text = "COMING SOON";

        const triggerFlip = async () => {
            const promises = slots.map((slot, i) => {
                const targetChar = text[i] || ' ';
                return slot.flip(targetChar, 'fast', i * 50); // Staggered flip
            });
            await Promise.all(promises);
        };

        // Initial flip after a short delay
        setTimeout(triggerFlip, 1500);

        // Repeat every 10 seconds
        setInterval(triggerFlip, 10000);
    });
</script>
